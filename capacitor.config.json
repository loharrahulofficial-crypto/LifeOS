{
  "appId": "com.lifeos.app",
  "appName": "LifeOS",
  "webDir": "dist",
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "initialFocus": true,
    "backgroundColor": "#0b0f1a"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1000,
      "launchAutoHide": true,
      "backgroundColor": "#0b0f1a",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}
