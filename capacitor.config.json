{
  "appId": "com.Techlife.lifeOS",
  "appName": "LifeOS",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "initialFocus": true,
    "backgroundColor": "#0b0f1a",
    "overScrollMode": "never"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1000,
      "launchAutoHide": true,
      "backgroundColor": "#0b0f1a",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}
